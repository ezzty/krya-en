---
import BaseLayout from './BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  description?: string;
  author: string;
  pubDate: string;
  wordCount?: number;
  tags?: string[];
  categories?: string[];
  thumbnail?: string;
}

const { title, description, author, pubDate, wordCount = 0, tags = [], categories = [], thumbnail } = Astro.props;

// Process og:image URL
const ogImage = thumbnail || 'https://krya.com/og-image.png';
---

<BaseLayout title={title} description={description || "Jin's personal blog"}>
  <NavBar slot="header" />
  
  <!-- Post page SEO meta - placed in head -->
  <meta slot="head" property="og:image" content={ogImage} />
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="article:published_time" content={pubDate} />
  {tags.length > 0 && (
    <meta slot="head" property="article:tag" content={tags.join(', ')} />
  )}
  
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "author": {
      "@type": "Person",
      "name": author
    },
    "datePublished": pubDate,
    "description": Astro.props.description || '',
    "url": Astro.url.href
  })} />
  
  <div class="col-mb-12" id="main" role="main">
    <article class="post">
      <h1 class="col-mb-12 post-title">
        <a href={Astro.url.pathname}>{title}</a>
      </h1>
      <ul class="col-mb-12 post-meta">
        <li>By <a href="/about">{author}</a></li>
        <li>{formatDate(pubDate)}</li>
        <li>{wordCount} words</li>
      </ul>
      <div class="col-mb-12 post-content">
        <slot />
      </div>
      
      {(categories.length > 0 || tags.length > 0) && (
        <div class="post-meta-bottom">
          {categories.length > 0 && (
            <span class="meta-item">
              Categories: {
                categories.map((category, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={`/categories/${encodeURIComponent(category)}`}>{category}</a>
                  </>
                ))
              }
            </span>
          )}
          {categories.length > 0 && tags.length > 0 && (
            <span class="meta-separator"> / </span>
          )}
          {tags.length > 0 && (
            <span class="meta-item">
              Tags: {
                tags.map((tag, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
                  </>
                ))
              }
            </span>
          )}
        </div>
      )}
    </article>
    
    <slot name="comments" />
  </div>
</BaseLayout>

<style>
.post-meta-bottom {
    margin-top: 40px;
    padding-top: 20px;
  color: #666;
  font-size: 0.95em;
  line-height: 2;
}
.meta-item a {
  color: #3354AA;
  text-decoration: none;
  transition: all 0.2s ease;
}
.meta-item a:hover {
  color: #1a3d8f;
  text-decoration: underline;
}
.meta-separator {
  color: #999;
  margin: 0 8px;
}
html[data-theme="dark"] .post-meta-bottom {
    color: #999;
  }
html[data-theme="dark"] .meta-item a {
  color: #5a8bff;
}
html[data-theme="dark"] .meta-item a:hover {
  color: #7aa5ff;
}
</style>
