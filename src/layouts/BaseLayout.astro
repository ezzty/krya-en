---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "krya" } = Astro.props;

// Import CSS files (Vite will bundle automatically)
import '../styles/grid.css';
import '../styles/style.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1" />
    <meta name="renderer" content="webkit" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Canonical URL (overridden on post pages) -->
    <link rel="canonical" href={`https://en.krya.com${Astro.url.pathname}`} />
    
    <!-- Additional head content (e.g. OG meta) -->
    <slot name="head" />
    
    <!-- CSS (imported for Vite bundling) -->
    
    <!-- Theme initialization - prevent dark mode flash -->
    <script is:inline>
      (function() {
        const html = document.documentElement;
        
        /**
         * Set theme
         */
        function setTheme(theme) {
          if (theme === 'dark') {
            html.setAttribute('data-theme', 'dark');
            html.style.colorScheme = 'dark';
          } else {
            html.removeAttribute('data-theme');
            html.style.colorScheme = 'light';
          }
          localStorage.setItem('theme', theme);
        }
        
        /**
         * Get current theme
         */
        function getTheme() {
          return localStorage.getItem('theme') || 
                 (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        }
        
        /**
         * Toggle theme
         */
        function toggleTheme() {
          const current = html.getAttribute('data-theme');
          const newTheme = current === 'dark' ? 'light' : 'dark';
          setTheme(newTheme);
          return newTheme;
        }
        
        // Expose to global
        window.ThemeManager = { setTheme, getTheme, toggleTheme };
        
        // Auto initialize
        const theme = getTheme();
        setTheme(theme);
      })();
    </script>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="krya - Jin's Blog" href="/rss.xml" />
  </head>
  <body>
    <slot name="header" />
    
    <div id="body">
      <div class="container">
        <div class="colgroup">
          <slot />
        </div>
      </div>
    </div>
    
    <footer id="footer" role="contentinfo">
      © 2008-{new Date().getFullYear()}. Astro & <a href="https://github.com/ezzty/krya-en" target="_blank" rel="noopener noreferrer" class="footer-link">Sintu Theme</a>
      <br />
      Stay Young ♥️ Stay Simple
      <div class="footer-social">
        <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="social-link" title="RSS Feed">
          <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.1 10.888a1.811 1.811 0 0 1 .002 2.563H3.1c-.33.331-.782.531-1.284.531s-.953-.201-1.283-.531a1.807 1.807 0 0 1 0-2.563 1.811 1.811 0 0 1 2.567 0zm0 0h.001H3.1zM.533 13.451c-.001 0-.001 0 0 0zM.001 4.952V7.57a6.358 6.358 0 0 1 4.525 1.885 6.405 6.405 0 0 1 1.876 4.541V14h2.622a9.038 9.038 0 0 0-2.647-6.393A8.988 8.988 0 0 0 .001 4.952zM.006.291v2.617C6.1 2.911 11.054 7.886 11.058 14h2.618a13.694 13.694 0 0 0-4.011-9.688A13.609 13.609 0 0 0 .006.291z"/>
            </svg>
          </span>
        </a>
      </div>
    </footer>
    
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="9f0742ab-e931-4ae5-a978-6e0c611cc1b8"></script>
    
    <!-- Main JS -->
    <script src="/js/main.js" is:inline></script>
  </body>
</html>
